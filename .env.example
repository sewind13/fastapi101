APP__NAME="FastAPI Template"
APP__DEBUG="false"
APP__ENV="development"
APP__PUBLIC_BASE_URL="http://localhost:8000"
EXAMPLES__ENABLE_ITEMS_MODULE="true"

# Local-only compose credentials. Do not reuse these in shared environments.
LOCAL_POSTGRES_DB="app"
LOCAL_POSTGRES_USER="app"
LOCAL_POSTGRES_PASSWORD="app"
LOCAL_RABBITMQ_USER="guest"
LOCAL_RABBITMQ_PASSWORD="guest"

API__V1_PREFIX="/api/v1"
API__CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'
API__PUBLIC_REGISTRATION_ENABLED="false"

SECURITY__SECRET_KEY="change-me"
SECURITY__ALGORITHM="HS256"
SECURITY__ISSUER="your-template"
SECURITY__AUDIENCE="your-template-users"
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES="30"
SECURITY__REFRESH_TOKEN_EXPIRE_MINUTES="10080"
SECURITY__PASSWORD_MIN_LENGTH="8"
SECURITY__PASSWORD_REQUIRE_UPPERCASE="false"
SECURITY__PASSWORD_REQUIRE_LOWERCASE="true"
SECURITY__PASSWORD_REQUIRE_DIGIT="false"
SECURITY__PASSWORD_REQUIRE_SPECIAL="false"
SECURITY__PASSWORD_FORBID_USERNAME="true"
SECURITY__PASSWORD_FORBID_EMAIL_LOCALPART="true"
SECURITY__EMAIL_VERIFICATION_ENABLED="true"
SECURITY__EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES="1440"
SECURITY__REQUIRE_VERIFIED_EMAIL_FOR_LOGIN="false"

AUTH_RATE_LIMIT__ENABLED="true"
AUTH_RATE_LIMIT__BACKEND="memory"
AUTH_RATE_LIMIT__REDIS_URL="redis://redis:6379/0"
AUTH_RATE_LIMIT__KEY_PREFIX="rate_limit"
AUTH_RATE_LIMIT__TRUST_PROXY_HEADERS="false"
AUTH_RATE_LIMIT__TRUSTED_PROXY_CIDRS='["127.0.0.1/32","::1/128"]'
AUTH_RATE_LIMIT__ACCOUNT_LOCKOUT_ENABLED="true"
AUTH_RATE_LIMIT__ACCOUNT_LOCKOUT_MAX_ATTEMPTS="5"
AUTH_RATE_LIMIT__ACCOUNT_LOCKOUT_SECONDS="900"
AUTH_RATE_LIMIT__LOGIN_MAX_ATTEMPTS="5"
AUTH_RATE_LIMIT__LOGIN_WINDOW_SECONDS="300"
AUTH_RATE_LIMIT__TOKEN_MAX_ATTEMPTS="20"
AUTH_RATE_LIMIT__TOKEN_WINDOW_SECONDS="60"

DATABASE__URL="postgresql+psycopg://app:app@db:5432/app"
DATABASE__ECHO="false"
DATABASE__POOL_SIZE="10"
DATABASE__MAX_OVERFLOW="20"
DATABASE__POOL_TIMEOUT="30"
DATABASE__POOL_RECYCLE="1800"

LOGGING__LEVEL="INFO"
LOGGING__AUDIT_LEVEL="INFO"
LOGGING__SCHEMA_VERSION="1.0"
LOGGING__ACCESS_LOG_SAMPLE_RATE="1.0"
LOGGING__ACCESS_LOG_SKIP_PATHS='["/health/live"]'
LOGGING__ACCESS_LOG_SKIP_PREFIXES='[]'
LOGGING__TRACE_HEADER_NAME="traceparent"

TELEMETRY__ENABLED="false"
TELEMETRY__SERVICE_NAME="your-template-service"
TELEMETRY__SERVICE_VERSION="0.1.0"
TELEMETRY__EXPORTER_OTLP_ENDPOINT=""
TELEMETRY__EXPORTER_OTLP_INSECURE="true"

METRICS__ENABLED="false"
METRICS__PATH="/metrics"
METRICS__INCLUDE_IN_SCHEMA="false"
METRICS__AUTH_TOKEN=""

EXTERNAL__TIMEOUT_SECONDS="10.0"
EXTERNAL__MAX_ATTEMPTS="3"
EXTERNAL__BACKOFF_SECONDS="0.5"
EXTERNAL__MAX_BACKOFF_SECONDS="5.0"
EXTERNAL__RETRY_ON_STATUSES='[429,500,502,503,504]'
SMTP__TIMEOUT_SECONDS="10.0"
SMTP__MAX_ATTEMPTS="3"
SMTP__BACKOFF_SECONDS="0.5"
SMTP__MAX_BACKOFF_SECONDS="5.0"
SMTP__RETRY_ON_STATUSES='[429,500,502,503,504]'
SENDGRID__TIMEOUT_SECONDS="10.0"
SENDGRID__MAX_ATTEMPTS="3"
SENDGRID__BACKOFF_SECONDS="0.5"
SENDGRID__MAX_BACKOFF_SECONDS="5.0"
SENDGRID__RETRY_ON_STATUSES='[429,500,502,503,504]'
SES__TIMEOUT_SECONDS="10.0"
SES__MAX_ATTEMPTS="3"
SES__BACKOFF_SECONDS="0.5"
SES__MAX_BACKOFF_SECONDS="5.0"
SES__RETRY_ON_STATUSES='[429,500,502,503,504]'
WEBHOOK__TIMEOUT_SECONDS_POLICY="10.0"
WEBHOOK__MAX_ATTEMPTS="3"
WEBHOOK__BACKOFF_SECONDS="0.5"
WEBHOOK__MAX_BACKOFF_SECONDS="5.0"
WEBHOOK__RETRY_ON_STATUSES='[429,500,502,503,504]'
EXTERNAL_EVENT_POLICIES__EMAIL_SEND_PASSWORD_RESET__MAX_ATTEMPTS="5"
EXTERNAL_EVENT_POLICIES__EMAIL_SEND_PASSWORD_RESET__BACKOFF_SECONDS="1.0"
EXTERNAL_EVENT_POLICIES__WEBHOOK_WORKER_FAILURE_ALERT__MAX_ATTEMPTS="6"
EXTERNAL_EVENT_POLICIES__WEBHOOK_WORKER_FAILURE_ALERT__RETRY_ON_STATUSES='[429,500,502,503,504]'

CACHE__ENABLED="false"
CACHE__BACKEND="memory"
CACHE__REDIS_URL="redis://redis:6379/2"
CACHE__KEY_PREFIX="cache"
CACHE__DEFAULT_TTL_SECONDS="60"
CACHE__ITEMS_LIST_TTL_SECONDS="30"

OPS__ENABLED="true"

EMAIL__ENABLED="false"
EMAIL__DRY_RUN="true"
EMAIL__PROVIDER="smtp"
EMAIL__HOST=""
EMAIL__PORT="587"
EMAIL__USERNAME=""
EMAIL__PASSWORD=""
EMAIL__USE_TLS="true"
EMAIL__FROM_EMAIL="no-reply@example.com"
EMAIL__SENDGRID_API_KEY=""
EMAIL__SENDGRID_API_BASE_URL="https://api.sendgrid.com/v3/mail/send"
EMAIL__SENDGRID_TIMEOUT_SECONDS="10.0"
EMAIL__SENDGRID_CATEGORIES='["welcome","signup"]'
EMAIL__SENDGRID_CUSTOM_ARGS='{"tenant":"acme","flow":"signup"}'
EMAIL__SENDGRID_WELCOME_TEMPLATE_ID=""
EMAIL__SENDGRID_PASSWORD_RESET_TEMPLATE_ID=""
EMAIL__SENDGRID_VERIFICATION_TEMPLATE_ID=""
EMAIL__SES_REGION="ap-southeast-1"
EMAIL__SES_CONFIGURATION_SET=""
EMAIL__SES_PROFILE_NAME=""
EMAIL__SES_ACCESS_KEY_ID=""
EMAIL__SES_SECRET_ACCESS_KEY=""
EMAIL__SES_SESSION_TOKEN=""
EMAIL__SES_WELCOME_TEMPLATE_NAME=""
EMAIL__SES_PASSWORD_RESET_TEMPLATE_NAME=""
EMAIL__SES_VERIFICATION_TEMPLATE_NAME=""

WEBHOOK__ENABLED="false"
WEBHOOK__DRY_RUN="true"
WEBHOOK__PROVIDER="generic"
WEBHOOK__USER_REGISTERED_URL=""
WEBHOOK__TIMEOUT_SECONDS="5.0"
WEBHOOK__AUTH_HEADER_NAME=""
WEBHOOK__AUTH_HEADER_VALUE=""
WEBHOOK__SLACK_WEBHOOK_URL=""
WEBHOOK__SLACK_CHANNEL=""
WEBHOOK__SLACK_USERNAME=""
WEBHOOK__SLACK_ICON_EMOJI=""
WEBHOOK__SLACK_ROUTE_URLS='{"user_registered":"https://hooks.slack.com/services/replace-me","worker_failure":"https://hooks.slack.com/services/replace-me-alerts"}'
WEBHOOK__ALLOWED_HOSTS='["hooks.example.com","hooks.slack.com"]'
WEBHOOK__ALLOW_PRIVATE_TARGETS="false"
WEBHOOK__REQUIRE_HTTPS="true"

WORKER__ENABLED="false"
WORKER__BROKER_URL="amqp://your-rabbitmq-user:your-rabbitmq-password@queue:5672/"
WORKER__QUEUE_NAME="app.default"
WORKER__RETRY_QUEUE_NAME="app.default.retry"
WORKER__DEAD_LETTER_QUEUE_NAME="app.default.dlq"
WORKER__PREFETCH_COUNT="10"
WORKER__MAX_RETRIES="3"
WORKER__RETRY_DELAY_MS="30000"
WORKER__MAX_RETRY_DELAY_MS="300000"
WORKER__REQUEUE_ON_FAILURE="false"
WORKER__IDEMPOTENCY_ENABLED="true"
WORKER__IDEMPOTENCY_BACKEND="memory"
WORKER__IDEMPOTENCY_REDIS_URL="redis://redis:6379/1"
WORKER__IDEMPOTENCY_KEY_PREFIX="worker_idempotency"
WORKER__IDEMPOTENCY_TTL_SECONDS="86400"

HEALTH__TIMEOUT_SECONDS="2.0"
HEALTH__ENABLE_REDIS_CHECK="false"
HEALTH__REDIS_URL="redis://redis:6379/0"
HEALTH__ENABLE_S3_CHECK="false"
HEALTH__S3_ENDPOINT_URL="https://s3.amazonaws.com"
HEALTH__S3_BUCKET_NAME="your-bucket-name"
HEALTH__S3_REGION="ap-southeast-1"
HEALTH__ENABLE_QUEUE_CHECK="false"
HEALTH__QUEUE_URL="amqp://your-rabbitmq-user:your-rabbitmq-password@queue:5672/"
