APP__NAME="Your Product API"
APP__ENV="development"
APP__PUBLIC_BASE_URL="http://localhost:8000"

LOCAL_POSTGRES_DB="app"
LOCAL_POSTGRES_USER="app"
LOCAL_POSTGRES_PASSWORD="app"

API__V1_PREFIX="/api/v1"
API__CORS_ORIGINS='["http://localhost:3000"]'
API__PUBLIC_REGISTRATION_ENABLED="false"

SECURITY__SECRET_KEY="replace-with-a-real-secret"
SECURITY__ISSUER="your-product"
SECURITY__AUDIENCE="your-product-users"

DATABASE__URL="postgresql+psycopg://app:app@db:5432/app"

METRICS__ENABLED="false"
METRICS__AUTH_TOKEN=""
