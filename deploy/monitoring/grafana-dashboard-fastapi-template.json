  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(fastapi_template_http_requests_total[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "title": "5xx Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(fastapi_template_http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(fastapi_template_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "title": "In-Flight Requests",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(fastapi_template_http_requests_in_progress)",
          "legendFormat": "in-flight"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "title": "Auth Events",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (event, outcome) (rate(fastapi_template_auth_events_total[5m]))",
          "legendFormat": "{{event}} {{outcome}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      }
    },
    {
      "title": "Readiness Dependency Status",
      "type": "timeseries",
      "targets": [
        {
          "expr": "fastapi_template_readiness_dependency_status",
          "legendFormat": "{{dependency}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      }
    }
  ],
